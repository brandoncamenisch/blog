---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <h2>
      <a href="/">
        <span class="icon" aria-hidden="true"></span>
        <span>{SITE_TITLE}</span>
      </a>
    </h2>
    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>
    <div class="social-links">
      <a href="/rss.xml" title="RSS feed">
        <span class="sr-only">View the RSS feed</span>
        <span class="icon" aria-hidden="true"></span>
      </a>
      <a href="https://github.com/brandoncamenisch/blog" target="_blank" title="Blog repository">
        <span class="sr-only">Go to the blog GitHub repository</span>
        <span class="icon" aria-hidden="true"></span>
      </a>
    </div>
  </nav>
</header>
<style>
  header {
    margin: 0;
    padding: 0 1em;
    background: rgba(var(--surface), 0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(var(--border), 0.6);
    box-shadow: 0 0 30px rgba(var(--glow), 0.12);
  }
  h2 {
    margin: 0;
    font-size: 1em;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  h2 a,
  h2 a.active {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  nav a {
    padding: 1em 0.5em;
    color: rgb(var(--text));
    border-bottom: 4px solid transparent;
    text-decoration: none;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: rgb(var(--accent));
    color: rgb(var(--accent-bright));
    text-shadow: 0 0 10px rgba(var(--glow), 0.5);
  }
  .internal-links {
    display: flex;
    gap: 0.25rem;
  }
  .icon {
    font-family: 'NotoMonoNerd', monospace;
    color: rgb(var(--accent-bright));
    font-size: 1.2em;
    line-height: 1;
    text-shadow: 0 0 10px rgba(var(--glow), 0.55);
  }
  .social-links,
  .social-links a {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .social-links a {
    font-size: 1.25rem;
  }
  @media (max-width: 720px) {
    nav {
      flex-wrap: wrap;
      justify-content: center;
    }
    .social-links {
      width: 100%;
      justify-content: center;
    }
  }
</style>
