---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <div class="session-status">
      <span class="status-chip session">
        <span class="icon" aria-hidden="true"></span>
        <span>{SITE_TITLE}</span>
      </span>
      <span class="status-chip host">
        <span class="icon" aria-hidden="true">󰒋</span>
        <span>blog.brandoncamenisch.com</span>
      </span>
    </div>

    <div class="window-tabs">
      <HeaderLink href="/">
        <span class="icon" aria-hidden="true">󰆍</span>
        <span>home</span>
      </HeaderLink>
      <HeaderLink href="/blog">
        <span class="icon" aria-hidden="true">󰂺</span>
        <span>blog</span>
      </HeaderLink>
      <HeaderLink href="/about">
        <span class="icon" aria-hidden="true">󰋼</span>
        <span>about</span>
      </HeaderLink>
    </div>

    <div class="social-links">
      <a href="/rss.xml" title="RSS feed">
        <span class="sr-only">View the RSS feed</span>
        <span class="icon" aria-hidden="true"></span>
      </a>
      <a href="https://github.com/brandoncamenisch/blog" target="_blank" title="Blog repository">
        <span class="sr-only">Go to the blog GitHub repository</span>
        <span class="icon" aria-hidden="true"></span>
      </a>
    </div>
  </nav>
</header>
<style>
  header {
    margin: 0 auto;
    width: min(1120px, calc(100% - 2rem));
    padding-top: 1rem;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    padding: 0.45rem 0.65rem;
    background: rgba(var(--surface), 0.96);
    border: 1px solid rgba(var(--border), 0.48);
    border-radius: 14px 14px 0 0;
    box-shadow: var(--box-shadow);
  }
  .session-status,
  .window-tabs,
  .social-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .status-chip,
  .window-tabs :global(a) {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.2rem;
    padding: 0 0.85rem;
    border-radius: 9px;
    border: 1px solid rgba(var(--border), 0.4);
    background: rgba(var(--surface-alt), 0.95);
    color: rgb(var(--text));
    text-decoration: none;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.88rem;
  }
  .window-tabs :global(a.active) {
    border-color: rgba(var(--accent), 0.8);
    background: rgba(var(--accent), 0.12);
    color: rgb(var(--accent-bright));
    text-shadow: 0 0 10px rgba(var(--glow), 0.5);
  }
  .icon {
    font-family: 'NotoMonoNerd', monospace;
    color: rgb(var(--accent-bright));
    font-size: 1.2em;
    line-height: 1;
    text-shadow: 0 0 10px rgba(var(--glow), 0.55);
  }
  .social-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.2rem;
    min-height: 2.2rem;
    border-radius: 9px;
    border: 1px solid rgba(var(--border), 0.4);
    background: rgba(var(--surface-alt), 0.95);
    font-size: 1.25rem;
    color: rgb(var(--accent-bright));
  }
  @media (max-width: 720px) {
    nav {
      flex-wrap: wrap;
      justify-content: center;
    }
    .session-status,
    .window-tabs,
    .social-links {
      width: 100%;
      justify-content: center;
      flex-wrap: wrap;
    }
    .social-links {
      padding-top: 0.2rem;
    }
  }
</style>
