---
const today = new Date();
---

<footer>
  <div class="status-line">
    <span class="icon" aria-hidden="true"></span>
    <span>&copy; {today.getFullYear()} Brandon Camenisch · deployed via GitHub Pages</span>
  </div>
  <div class="social-links">
    <a href="/rss.xml" title="RSS feed">
      <span class="sr-only">View the RSS feed</span>
      <span class="icon" aria-hidden="true"></span>
    </a>
    <a href="https://github.com/brandoncamenisch/blog" target="_blank" title="Blog repository">
      <span class="sr-only">Go to the blog GitHub repository</span>
      <span class="icon" aria-hidden="true"></span>
    </a>
  </div>
</footer>
<style>
  footer {
    padding: 2em 1em 6em 1em;
    background: transparent;
    color: rgb(var(--muted));
    text-align: center;
    border-top: 1px solid rgba(var(--border), 0.35);
  }
  .status-line {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .social-links {
    display: flex;
    justify-content: center;
    gap: 1em;
    margin-top: 1em;
  }
  .social-links a {
    text-decoration: none;
    color: rgb(var(--muted));
    font-size: 1.25rem;
  }
  .social-links a:hover {
    color: rgb(var(--text));
  }
  .icon {
    font-family: 'NotoMonoNerd', monospace;
    color: rgb(var(--accent-bright));
    text-shadow: 0 0 10px rgba(var(--glow), 0.55);
  }
</style>
