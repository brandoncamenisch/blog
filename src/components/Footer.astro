---
const today = new Date();
---

<footer>
  <div class="status-line left">
    <span class="segment">
      <span class="icon" aria-hidden="true"></span>
      <span>session:blog</span>
    </span>
    <span class="segment">
      <span class="icon" aria-hidden="true"></span>
      <span>branch:main</span>
    </span>
  </div>
  <div class="status-line middle">
    <span class="segment">
      <span class="icon" aria-hidden="true">󱂬</span>
      <span>github-pages</span>
    </span>
    <span class="segment">
      <span class="icon" aria-hidden="true"></span>
      <span>/blog</span>
    </span>
  </div>
  <div class="status-line right">
    <a href="/rss.xml" title="RSS feed">
      <span class="sr-only">View the RSS feed</span>
      <span class="icon" aria-hidden="true"></span>
    </a>
    <a href="https://github.com/brandoncamenisch/blog" target="_blank" title="Blog repository">
      <span class="sr-only">Go to the blog GitHub repository</span>
      <span class="icon" aria-hidden="true"></span>
    </a>
  </div>
</footer>
<style>
  footer {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto 3rem;
    padding: 0.55rem 0.7rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0.8rem;
    background: rgba(var(--surface), 0.96);
    border: 1px solid rgba(var(--border), 0.48);
    border-top: none;
    border-radius: 0 0 14px 14px;
    box-shadow: var(--box-shadow);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--muted));
    font-size: 0.78rem;
  }
  .status-line {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .middle {
    justify-content: center;
  }
  .right {
    justify-content: flex-end;
  }
  .segment,
  .right a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 2rem;
    padding: 0 0.75rem;
    border-radius: 8px;
    border: 1px solid rgba(var(--border), 0.32);
    background: rgba(var(--surface-alt), 0.92);
  }
  .right a {
    text-decoration: none;
    color: rgb(var(--muted));
  }
  .right a:hover {
    color: rgb(var(--text));
  }
  .icon {
    font-family: 'NotoMonoNerd', monospace;
    color: rgb(var(--accent-bright));
    text-shadow: 0 0 10px rgba(var(--glow), 0.55);
  }
  @media (max-width: 860px) {
    footer {
      grid-template-columns: 1fr;
    }
    .left,
    .middle,
    .right {
      justify-content: center;
      flex-wrap: wrap;
    }
  }
</style>
