---
import HeaderLink from './HeaderLink.astro';
const { count } = Astro.props;
---

<nav class="tmux-bar">
  <div class="tmux-tabs">
    <HeaderLink href="/">
      <span class="win-idx">1</span>
      <span class="nf" aria-hidden="true">󰆍</span>
      <span>home</span>
    </HeaderLink>
    <HeaderLink href="/work">
      <span class="win-idx">2</span>
      <span class="nf" aria-hidden="true">󰂺</span>
      <span>work</span>
    </HeaderLink>
    <HeaderLink href="/life">
      <span class="win-idx">3</span>
      <span class="nf" aria-hidden="true">󰙊</span>
      <span>life</span>
    </HeaderLink>
  </div>

  <div class="tmux-right">
    {count != null && (
      <span class="seg seg-count">{count} posts</span>
    )}
    <span class="sep sep-c" aria-hidden="true"></span>
    <span class="seg seg-info">
      <span class="nf" aria-hidden="true">󱂬</span>
      <span>brandoncamenisch.com</span>
    </span>
    <span class="seg seg-links">
      <a href="/time" title="Timeline">
        <span class="sr-only">Timeline</span>
        <span class="nf" aria-hidden="true"></span>
      </a>
      <a href="https://github.com/brandoncamenisch" target="_blank" title="GitHub">
        <span class="sr-only">GitHub</span>
        <span class="nf" aria-hidden="true"></span>
      </a>
      <a href="/rss.xml" target="_blank" title="RSS Feed">
        <span class="sr-only">RSS</span>
        <span class="nf" aria-hidden="true"></span>
      </a>
    </span>
  </div>
</nav>

<style>
  .tmux-bar {
    display: flex;
    align-items: stretch;
    justify-content: flex-start;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    width: 100%;
    background: rgb(var(--black));
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-family: 'JetBrainsMonoNerd', monospace;
    border-top: 1px solid rgba(var(--border), 0.15);
  }

  .tmux-right {
    display: flex;
    align-items: stretch;
    flex-shrink: 0;
    margin-left: auto;
  }

  .tmux-tabs {
    display: flex;
    align-items: stretch;
  }

  .seg {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.4rem 0.8rem;
    white-space: nowrap;
  }

  .sep {
    display: flex;
    align-items: center;
    font-family: 'JetBrainsMonoNerd', monospace;
    font-size: 1.45rem;
    line-height: 1;
    padding: 0;
  }

  .sep-c {
    color: rgb(var(--surface-alt));
    background: rgb(var(--black));
  }
  .seg-count {
    color: rgba(210, 80, 80, 0.85);
    font-size: 0.75em;
    letter-spacing: 0.08em;
  }
  .seg-info {
    background: rgb(var(--surface-alt));
    color: rgb(var(--muted));
  }
  .sep-d {
    color: rgb(var(--accent-dark));
    background: rgb(var(--surface-alt));
  }
  .seg-links {
    color: rgb(var(--muted));
    gap: 0.2rem;
  }
  .seg-links a {
    color: rgb(var(--accent-bright));
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    padding: 0 0.25rem;
    transition: color 0.15s;
  }
  .seg-links a:hover {
    color: rgb(var(--text));
  }

  .tmux-tabs :global(a) {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.9rem;
    color: rgb(var(--muted));
    text-decoration: none;
    border-right: 1px solid rgba(var(--border), 0.12);
    transition: color 0.15s, background 0.15s;
  }
  .tmux-tabs :global(a.active) {
    color: rgb(var(--accent-bright));
    background: rgba(var(--accent), 0.08);
    font-weight: 700;
    text-shadow: 0 0 8px rgba(var(--glow), 0.4);
  }
  .tmux-tabs :global(a:hover:not(.active)) {
    color: rgb(var(--text));
    background: rgba(var(--surface-alt), 0.5);
  }

  .win-idx {
    color: rgba(var(--muted), 0.55);
    font-size: 0.75em;
  }
  .nf {
    font-family: 'JetBrainsMonoNerd', monospace;
    font-size: 1rem;
    line-height: 1;
  }

  @media (max-width: 720px) {
    .tmux-bar {
      flex-wrap: wrap;
    }
    .tmux-tabs {
      width: 100%;
      border-bottom: 1px solid rgba(var(--border), 0.15);
      justify-content: center;
      flex-wrap: wrap;
    }
    .tmux-right {
      width: 100%;
      justify-content: flex-end;
    }
  }
</style>
