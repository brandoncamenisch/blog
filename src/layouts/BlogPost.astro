---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

interface Props extends CollectionEntry<'work'>['data'] {
	prev?: CollectionEntry<'work'> | null;
	next?: CollectionEntry<'work'> | null;
}

const { title, description, pubDate, updatedDate, heroImage, hallucination, signa, prev, next } = Astro.props;
const stringHeroImage = typeof heroImage === 'string' ? heroImage : undefined;
const postClass = signa ? 'is-signal' : hallucination ? 'is-hallucination' : '';
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			*,
			*::before,
			*::after {
				box-sizing: border-box;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				width: 100%;
				max-width: 100%;
				height: auto;
				max-height: 480px;
				object-fit: cover;
				object-position: center top;
				border-radius: 0;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 1.5em;
				color: rgb(var(--text));
				background: rgba(var(--surface), 0.55);
				border: 1px solid rgba(var(--border), 0.35);
				border-radius: 0;
				box-shadow: var(--box-shadow);
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				line-height: 1.2;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--muted));
				text-transform: uppercase;
				letter-spacing: 0.08em;
				font-size: 0.9rem;
			}
			.last-updated-on {
				font-style: italic;
			}
			.prompt {
				color: rgb(var(--accent-bright));
				text-shadow: 0 0 10px rgba(var(--glow), 0.45);
			}
			.article-shell {
				display: grid;
				gap: 1rem;
			}
			.hero-image {
				background: rgba(var(--surface), 0.5);
				border: 1px solid rgba(var(--border), 0.35);
				border-radius: 0;
				padding: 0.8rem;
				box-shadow: var(--box-shadow);
			}
			.prose :global(.generated-article-image) {
				margin: 1.6rem 0;
				padding: 0.8rem;
				border: 1px solid rgba(var(--border), 0.3);
				border-radius: 0;
				background: rgba(var(--surface-alt), 0.38);
				box-shadow: var(--box-shadow);
			}
			.prose :global(.generated-article-image img) {
				display: block;
				width: 100%;
				max-width: 100%;
				height: auto;
				border-radius: 0;
				border: 1px solid rgba(var(--accent), 0.28);
			}
			.prose :global(.generated-article-image figcaption) {
				margin-top: 0.7rem;
				color: rgb(var(--muted));
				font-size: 0.92rem;
				line-height: 1.5;
			}
			@media (max-width: 720px) {
				main {
					width: 100%;
					padding: 0 0.75rem;
				}
				.prose {
					width: 100%;
					max-width: 100%;
					padding: 1rem;
				}
				.hero-image {
					padding: 0.5rem;
				}
				.prose :global(.generated-article-image) {
					margin: 1.2rem 0;
					padding: 0.6rem;
				}
			}
			.post-nav {
				display: flex;
				justify-content: space-between;
				align-items: stretch;
				gap: 0.75rem;
				padding: 0.75rem 0 0.25rem;
			}
			.post-nav a {
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
				padding: 0.6rem 0.9rem;
				background: rgba(var(--surface), 0.55);
				border: 1px solid rgba(var(--border), 0.35);
				color: rgb(var(--text));
				text-decoration: none;
				font-size: 0.8rem;
				line-height: 1.3;
				max-width: 48%;
				transition: border-color 0.15s, background 0.15s;
			}
			.post-nav a:hover {
				background: rgba(var(--surface), 0.8);
				border-color: rgba(var(--accent), 0.55);
			}
			.post-nav .nav-label {
				text-transform: uppercase;
				letter-spacing: 0.08em;
				font-size: 0.7rem;
				color: rgb(var(--accent-bright));
			}
			.post-nav .nav-title {
				color: rgb(var(--muted));
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.post-nav .nav-prev { text-align: left; }
			.post-nav .nav-next { text-align: right; margin-left: auto; }
			.post-nav .nav-spacer { flex: 1; }

		/* ── signal / hallucination theme ── */
		.article-shell { position: relative; }
		.article-shell::before {
			content: '';
			position: fixed;
			top: 0; left: 0; right: 0;
			height: 2px;
			z-index: 100;
			opacity: 0;
			animation: sweep 2.4s ease forwards 0.3s;
		}
		.article-shell.is-signal::before {
			background: linear-gradient(90deg, transparent 0%, rgba(220,60,60,0.9) 50%, transparent 100%);
			opacity: 1;
		}
		.article-shell.is-hallucination::before {
			background: linear-gradient(90deg, transparent 0%, rgba(60,100,230,0.9) 50%, transparent 100%);
			opacity: 1;
		}
		@keyframes sweep {
			from { background-position: -100% 0; }
			to   { background-position: 200% 0; }
		}
		.post-type-flag {
			display: inline-block;
			font-family: 'JetBrainsMonoNerd', monospace;
			font-size: 0.7rem;
			letter-spacing: 0.08em;
			margin-bottom: 0.4em;
		}
		.post-type-flag.is-signal        { color: rgba(200, 50, 50, 0.85); }
		.post-type-flag.is-hallucination { color: rgba(60, 100, 230, 0.85); }

		/* ── prose matrix rain canvas ── */
		.prose { position: relative; overflow: hidden; }
		.prose-matrix {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			pointer-events: none;
			z-index: 0;
			opacity: 0.45;
		}
		.prose > *:not(.prose-matrix) { position: relative; z-index: 1; }
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article class={`article-shell ${postClass}`}>
				<div class="hero-image">
					{
						heroImage &&
							(stringHeroImage ? (
								<img src={stringHeroImage} alt="" loading="eager" />
							) : (
								<Image width={1020} height={510} src={heroImage} alt="" />
							))
					}
				</div>
				<div class="prose">
					{postClass && <canvas class="prose-matrix" aria-hidden="true"></canvas>}
					<div class="title">
						<p class="prompt">$ cat post/{title.toLowerCase().replaceAll(' ', '-')}.md</p>
						{signa      && <span class="post-type-flag is-signal">! signal</span>}
						{hallucination && <span class="post-type-flag is-hallucination">! hallucination</span>}
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
			{(prev || next) && (
				<nav class="post-nav">
					{prev
						? <a href={`/work/${prev.id}`} class="nav-prev">
								<span class="nav-label">← prev</span>
								<span class="nav-title">{prev.data.title}</span>
							</a>
						: <span class="nav-spacer" />
					}
					{next
						? <a href={`/work/${next.id}`} class="nav-next">
								<span class="nav-label">next →</span>
								<span class="nav-title">{next.data.title}</span>
							</a>
						: <span class="nav-spacer" />
					}
				</nav>
			)}
		</main>
		<Footer />
	</body>
</html>

<script is:inline>
(function () {
  const canvas = document.querySelector('.prose-matrix');
  if (!canvas) return;
  const article = canvas.closest('.article-shell');
  const blu = article && article.classList.contains('is-hallucination');
  const CHARS = '0123456789ABCDEF01░▒█ ';
  const FONT  = 10;
  let timer = null;

  function start(w, h) {
    if (timer) clearInterval(timer);
    canvas.width  = w;
    canvas.height = h;
    const ctx  = canvas.getContext('2d');
    const cols = Math.floor(w / FONT);
    const drops = Array.from({length: cols}, () => Math.floor(Math.random() * -(h / FONT)));

    timer = setInterval(() => {
      /* fade-fill with the prose surface colour — gives the classic trailing effect */
      ctx.fillStyle = 'rgba(6, 18, 10, 0.1)';
      ctx.fillRect(0, 0, w, h);
      ctx.font = FONT + 'px monospace';
      for (let i = 0; i < cols; i++) {
        const y = drops[i];
        if (y < 0) { drops[i]++; continue; }
        const ch = CHARS[Math.floor(Math.random() * CHARS.length)];
        ctx.fillStyle = blu ? 'rgba(160,190,255,1)' : 'rgba(255,140,140,1)';
        ctx.fillText(ch, i * FONT, y * FONT);
        if (y * FONT > h && Math.random() > 0.975) drops[i] = Math.floor(Math.random() * -20);
        else drops[i]++;
      }
    }, 80);
  }

  const prose = canvas.parentElement;
  const ro = new ResizeObserver(entries => {
    const r = entries[0].contentRect;
    if (r.width > 0 && r.height > 0) start(Math.round(r.width), Math.round(r.height));
  });
  ro.observe(prose);
})();
</script>
