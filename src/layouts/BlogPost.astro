---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
const stringHeroImage = typeof heroImage === 'string' ? heroImage : undefined;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			*,
			*::before,
			*::after {
				box-sizing: border-box;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				width: 100%;
				max-width: 100%;
				height: auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1.5em;
				color: rgb(var(--text));
				background: rgba(var(--surface), 0.9);
				border: 1px solid rgba(var(--border), 0.35);
				border-radius: 14px;
				box-shadow: var(--box-shadow);
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				line-height: 1.2;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--muted));
				text-transform: uppercase;
				letter-spacing: 0.08em;
				font-size: 0.9rem;
			}
			.last-updated-on {
				font-style: italic;
			}
			.prompt {
				color: rgb(var(--accent-bright));
				text-shadow: 0 0 10px rgba(var(--glow), 0.45);
			}
			.article-shell {
				display: grid;
				gap: 1rem;
			}
			.hero-image {
				background: rgba(var(--surface), 0.86);
				border: 1px solid rgba(var(--border), 0.35);
				border-radius: 14px;
				padding: 0.8rem;
				box-shadow: var(--box-shadow);
			}
			.prose :global(.generated-article-image) {
				margin: 1.6rem 0;
				padding: 0.8rem;
				border: 1px solid rgba(var(--border), 0.3);
				border-radius: 14px;
				background: rgba(var(--surface-alt), 0.58);
				box-shadow: var(--box-shadow);
			}
			.prose :global(.generated-article-image img) {
				display: block;
				width: 100%;
				max-width: 100%;
				height: auto;
				border-radius: 10px;
				border: 1px solid rgba(var(--accent), 0.28);
			}
			.prose :global(.generated-article-image figcaption) {
				margin-top: 0.7rem;
				color: rgb(var(--muted));
				font-size: 0.92rem;
				line-height: 1.5;
			}
			@media (max-width: 720px) {
				main {
					width: 100%;
					padding: 0 0.75rem;
				}
				.prose {
					width: 100%;
					max-width: 100%;
					padding: 1rem;
				}
				.hero-image {
					padding: 0.5rem;
				}
				.prose :global(.generated-article-image) {
					margin: 1.2rem 0;
					padding: 0.6rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article class="article-shell">
				<div class="hero-image">
					{
						heroImage &&
							(stringHeroImage ? (
								<img src={stringHeroImage} alt="" loading="eager" />
							) : (
								<Image width={1020} height={510} src={heroImage} alt="" />
							))
					}
				</div>
				<div class="prose">
					<div class="title">
						<p class="prompt">$ cat post/{title.toLowerCase().replaceAll(' ', '-')}.md</p>
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
