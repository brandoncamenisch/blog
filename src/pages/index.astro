---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <h1>Notes from Brandon Camenisch</h1>
      <p>
        This is the publishing home for <a href="/blog">posts</a>, experiments, and longer
        writeups from Brandon Camenisch. The site is built with <a href="https://astro.build/">Astro</a>
        and deployed as a static site on GitHub Pages at <code>blog.brandoncamenisch.com</code>.
      </p>
      <p>
        The goal is to keep the stack lightweight, portable, and easy to version. Posts live in
        <code>src/content/blog/</code>, and every deploy is reproducible from code.
      </p>
      <p>Expect the content here to grow into a mix of:</p>
      <ul>
        <li>security research and debugging notes</li>
        <li>homelab and automation writeups</li>
        <li>development workflow experiments</li>
        <li>personal essays and project updates</li>
      </ul>
      <p>If you want the feed, the site also publishes <a href="/rss.xml">RSS</a>.</p>
    </main>
    <Footer />
  </body>
</html>
