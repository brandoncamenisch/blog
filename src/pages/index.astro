---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="terminal-panel hero">
        <p class="prompt">$ whoami</p>
        <h1>Brandon Camenisch // matrix log</h1>
        <p class="lede">
          A cyberpunk-flavored terminal for security notes, Linux automation, homelab experiments,
          and long-form project writeups.
        </p>
        <div class="hero-actions">
          <a class="terminal-link" href="/blog"><span aria-hidden="true"></span> open /blog</a>
          <a class="terminal-link" href="/rss.xml"><span aria-hidden="true"></span> subscribe /rss.xml</a>
        </div>
      </section>

      <section class="terminal-panel">
        <p class="prompt">$ cat mission.txt</p>
        <p>
          This site is built with <a href="https://astro.build/">Astro</a>, versioned in Git, and
          deployed to GitHub Pages. Posts live in <code>src/content/blog/</code>, and the whole
          publishing stack stays reproducible from code.
        </p>
      </section>

      <section class="terminal-panel">
        <p class="prompt">$ ls content/</p>
        <ul class="feature-list">
          <li><span aria-hidden="true"></span> security research and debugging notes</li>
          <li><span aria-hidden="true">󰒓</span> homelab and automation writeups</li>
          <li><span aria-hidden="true">󰛦</span> developer workflow experiments</li>
          <li><span aria-hidden="true">󰍩</span> essays, retrospectives, and project updates</li>
        </ul>
      </section>

      <section class="terminal-panel tmux-layout">
        <div class="pane">
          <p class="prompt">$ tmux list-panes</p>
          <p><span class="accent">pane 0</span> :: active writing workspace</p>
          <p><span class="accent">pane 1</span> :: rss + deploy pipeline</p>
          <p><span class="accent">pane 2</span> :: drafts / future posts</p>
        </div>
        <div class="pane">
          <p class="prompt">$ echo $STACK</p>
          <p>astro · markdown · github-pages · opentofu · cloudflare</p>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .hero {
    margin-bottom: 2rem;
  }
  .lede {
    font-size: 1.15rem;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.5rem;
  }
  .feature-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.8rem;
  }
  .feature-list li {
    display: flex;
    gap: 0.7rem;
    align-items: center;
  }
  .tmux-layout {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 1rem;
  }
  .pane {
    min-height: 100%;
    padding: 1rem;
    border: 1px solid rgba(var(--border), 0.25);
    border-radius: 10px;
    background: rgba(var(--surface-alt), 0.65);
  }
  .accent {
    color: rgb(var(--accent-bright));
  }
  @media (max-width: 720px) {
    .tmux-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
