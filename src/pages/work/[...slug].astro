---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const allPosts = (await getCollection('work')).sort(
		(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
	);
	return allPosts.map((post, index) => ({
		params: { slug: post.id },
		props: {
			post,
			prev: index > 0 ? allPosts[index - 1] : null,
			next: index < allPosts.length - 1 ? allPosts[index + 1] : null,
		},
	}));
}

interface Props {
	post: CollectionEntry<'work'>;
	prev: CollectionEntry<'work'> | null;
	next: CollectionEntry<'work'> | null;
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
const resolvedHeroImage = post.data.generatedHeroImage ?? post.data.heroImage;
---

<BlogPost {...post.data} heroImage={resolvedHeroImage} prev={prev} next={next}>
	<Content />
</BlogPost>
