---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 1040px;
			}
			.terminal-index {
				display: grid;
				gap: 1.2rem;
			}
			.intro-panel {
				padding: 1.2rem 1.4rem;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li {
				background: rgba(var(--surface), 0.88);
				border: 1px solid rgba(var(--border), 0.38);
				border-radius: 14px;
				padding: 1rem;
				box-shadow: var(--box-shadow);
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
				border: 1px solid rgba(var(--accent), 0.3);
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--text));
				line-height: 1;
				font-size: 1.2rem;
			}
			.date {
				margin: 0;
				color: rgb(var(--muted));
				text-transform: uppercase;
				letter-spacing: 0.08em;
				font-size: 0.85rem;
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent-bright));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			.post-label {
				display: inline-flex;
				align-items: center;
				gap: 0.45rem;
				margin-bottom: 0.8rem;
				color: rgb(var(--accent-bright));
				font-size: 0.85rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="terminal-index">
				<div class="terminal-panel intro-panel">
					<p class="prompt">$ ls -la /blog</p>
					<p>tmux-style scrollback of published entries, newest first.</p>
				</div>
				<ul>
					{
						posts.map((post) => (
							(() => {
								const heroImage = post.data.generatedHeroImage ?? post.data.heroImage;
								return (
							<li>
								<a href={`/blog/${post.id}/`}>
									<div class="post-label">
										<span aria-hidden="true"></span>
										<span>entry</span>
									</div>
									{heroImage &&
										(typeof heroImage === 'string' ? (
											<img src={heroImage} alt="" loading="lazy" />
										) : (
											<Image width={720} height={360} src={heroImage} alt="" />
										))}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
								);
							})()
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
